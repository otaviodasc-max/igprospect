{
  "manifest_version": 3,
  "name": "IGProspect - CRM de Prospecção",
  "version": "1.8.4",
  "description": "CRM no Instagram: detecta perfis, rastreia leads, converte por contato, envia áudios prontos no Direct, sincroniza com Agendor e com o Painel Privado.",
  "minimum_chrome_version": "111",
  "permissions": ["storage", "unlimitedStorage"],
  "host_permissions": ["https://api.agendor.com.br/*", "https://guuecwrhwuzbwfetehix.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["file:///*igprospect-dashboard*.html", "https://*.netlify.app/*", "https://igprospectleads.netlify.app/*", "https://otaviodasc-max.github.io/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
